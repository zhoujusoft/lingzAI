# Copy this file to `deploy/.env.dev` for local backend/middleware env injection.
# Frontend local development reads `frontend/packages/web/.env*`.

# Build network mirrors (for CN network environments)
MAVEN_MIRROR_URL=https://maven.aliyun.com/repository/public
PNPM_REGISTRY=https://registry.npmmirror.com
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn

# MySQL
MYSQL_ROOT_PASSWORD=change-me-password
MYSQL_DATABASE=lingzhou
MYSQL_USER=change-me-user
MYSQL_PASSWORD=change-me-password

# MinIO
MINIO_ROOT_USER=change-me-user
MINIO_ROOT_PASSWORD=change-me-password
MINIO_BUCKET=documents

# Chat model
APP_CHAT_MEMORY_TYPE=in-memory
APP_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
APP_CHAT_API_KEY=change-me-api-key
APP_CHAT_MODEL=qwen3-max

# Embedding model
APP_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
APP_EMBEDDING_API_KEY=change-me-api-key
APP_EMBEDDING_MODEL=text-embedding-v4
APP_EMBEDDING_EMBEDDINGS_PATH=/v1/embeddings
APP_EMBEDDING_DIMENSIONS=1024

# Elasticsearch
ES_JAVA_OPTS=-Xms1g -Xmx1g
APP_RAG_ELASTICSEARCH_INDEX_NAME=rag_chunks
APP_RAG_ELASTICSEARCH_DIMENSIONS=1024
APP_RAG_ELASTICSEARCH_SIMILARITY=cosine
APP_RAG_ELASTICSEARCH_SHARDS=1
APP_RAG_ELASTICSEARCH_REPLICAS=0

# Rerank
APP_RAG_RERANK_ENABLED=true
APP_RAG_RERANK_BASE_URL=https://dashscope.aliyuncs.com
APP_RAG_RERANK_API_KEY=change-me-api-key
APP_RAG_RERANK_PATH=/api/v1/services/rerank/text-rerank/text-rerank
APP_RAG_RERANK_MODEL=gte-rerank-v2
