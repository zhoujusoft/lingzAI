# General
TZ=Asia/Shanghai
FRONTEND_PORT=80

# Release image settings (keep in sync with release.env)
REGISTRY=125.75.152.167:5001
IMAGE_TAG=1.2.0
FRONTEND_IMAGE_NAME=lingzhou-frontend
BACKEND_IMAGE_NAME=lingzhou-backend

# Runtime
APP_CHAT_MEMORY_TYPE=in-memory

# Build network mirrors (for CN network environments)
MAVEN_MIRROR_URL=https://maven.aliyun.com/repository/public
PNPM_REGISTRY=https://registry.npmmirror.com

# MySQL
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=lingzhou
MYSQL_USER=sqluser
MYSQL_PASSWORD=Pass@word

# MinIO
MINIO_ROOT_USER=zhouju
MINIO_ROOT_PASSWORD=zhouju01
MINIO_BUCKET=documents

# Frontend build
VITE_BASE_PATH=/
VITE_BASE_URL=

# Qwen model runtime
MODEL_QWEN_CHAT_TEMPERATURE=
MODEL_QWEN_CHAT_MAX_TOKENS=
MODEL_QWEN_CHAT_SYSTEM_PROMPT=
MODEL_QWEN_CHAT_ENABLE_THINKING=false
MODEL_QWEN_EMBEDDING_DIMENSIONS=1024
MODEL_QWEN_RERANK_PROTOCOL=dashscope
MODEL_QWEN_RERANK_TIMEOUT_MS=1200
MODEL_QWEN_RERANK_FALLBACK_RRF=true

# vLLM model runtime
MODEL_VLLM_CHAT_TEMPERATURE=0.7
MODEL_VLLM_CHAT_MAX_TOKENS=20000
MODEL_VLLM_CHAT_SYSTEM_PROMPT=
MODEL_VLLM_CHAT_ENABLE_THINKING=false
MODEL_VLLM_EMBEDDING_DIMENSIONS=0
MODEL_VLLM_RERANK_PROTOCOL=vllm
MODEL_VLLM_RERANK_TIMEOUT_MS=1200
MODEL_VLLM_RERANK_FALLBACK_RRF=true

# Elasticsearch
ES_JAVA_OPTS=-Xms1g -Xmx1g
APP_RAG_ELASTICSEARCH_INDEX_NAME=rag_chunks
APP_RAG_ELASTICSEARCH_DIMENSIONS=1024
APP_RAG_ELASTICSEARCH_SIMILARITY=cosine
APP_RAG_ELASTICSEARCH_SHARDS=1
APP_RAG_ELASTICSEARCH_REPLICAS=0

# Rerank
APP_RAG_RERANK_ENABLED=true
APP_RAG_RERANK_TIMEOUT_MS=1200
APP_RAG_RERANK_FALLBACK_RRF=true
